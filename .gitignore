# ============================================================
# RAPIDA Crisis Mapping — .gitignore
# ============================================================

# ----------------------------------------------------------
# Node.js / npm
# ----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp.*
.yarn/

# ----------------------------------------------------------
# Build output
# ----------------------------------------------------------
dist/
build/
out/
.output/
.nuxt/
.next/

# ----------------------------------------------------------
# Environment & secrets — NEVER commit these
# ----------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/
docker/ssl/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/
*.log.*
pids/
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------
# OS / editor artifacts
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# IDEs
# ----------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath

# ----------------------------------------------------------
# Testing & coverage
# ----------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
junit.xml

# ----------------------------------------------------------
# TypeScript
# ----------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ----------------------------------------------------------
# Prisma
# ----------------------------------------------------------
prisma/dev.db
prisma/dev.db-journal
prisma/*.db

# ----------------------------------------------------------
# Docker volumes (if bind-mounted locally)
# ----------------------------------------------------------
postgres_data/
minio_data/
.docker-volumes/

# ----------------------------------------------------------
# Misc / local overrides
# ----------------------------------------------------------
*.local
.cache/
tmp/
temp/
.tmp/
*.bak
*.orig

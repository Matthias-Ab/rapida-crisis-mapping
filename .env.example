# ============================================================
# RAPIDA Crisis Mapping — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ----------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# ----------------------------------------------------------
DATABASE_URL=postgresql://crisis_user:changeme@postgres:5432/crisis_mapper
POSTGRES_USER=crisis_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=crisis_mapper

# ----------------------------------------------------------
# Object Storage (MinIO / S3-compatible)
# ----------------------------------------------------------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crisis-reports
MINIO_USE_SSL=false

# ----------------------------------------------------------
# Backend API
# ----------------------------------------------------------
NODE_ENV=development
PORT=3001

# Must be replaced with a strong random secret in production:
# openssl rand -hex 32
DASHBOARD_API_KEY=change_this_to_a_secure_random_key

# ----------------------------------------------------------
# Frontend (Vite — values are baked in at build time)
# ----------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_DASHBOARD_KEY=change_this
VITE_ENABLE_AI=true

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

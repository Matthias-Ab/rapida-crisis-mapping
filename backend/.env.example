# ============================================================
# RAPIDA Backend — Local development environment template
# Copy to .env and fill in your values before running.
# ============================================================

# Node environment: development | production | test
NODE_ENV=development

# Express server port
PORT=3001

# ---------------------------------------------------------------
# PostgreSQL + PostGIS
# For local dev without Docker: assumes a local Postgres instance
# with the postgis extension installed.
# ---------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rapida_dev?schema=public

# ---------------------------------------------------------------
# MinIO object storage
# For local dev: run MinIO with `minio server /data` or via Docker
#   docker run -p 9000:9000 -p 9001:9001 \
#     -e MINIO_ROOT_USER=minioadmin \
#     -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio server /data --console-address ":9001"
# ---------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crisis-reports

# Optional: public base URL for MinIO (e.g. via nginx proxy).
# If set, photo/thumbnail URLs will use this instead of
# http://MINIO_ENDPOINT:MINIO_PORT
# MINIO_PUBLIC_URL=http://localhost:9000

# ---------------------------------------------------------------
# API authentication
# Used to protect dashboard / export / analytics endpoints.
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------
DASHBOARD_API_KEY=change-me-use-openssl-rand-hex-32

# ---------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# Use * to allow all origins (development only).
# ---------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------
# Security
# Optional salt appended to IPs before SHA-256 hashing.
# Generate with: openssl rand -hex 16
# ---------------------------------------------------------------
IP_HASH_SALT=change-me-random-salt

{
  "name": "rapida-backend",
  "version": "1.0.0",
  "description": "RAPIDA Crisis Mapping Backend API",
  "license": "MIT",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "test": "jest --runInBand",
    "lint": "eslint src/",
    "seed": "node scripts/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "passWithNoTests": true
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "minio": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.5.0"
  }
}
